# ============================================================
# ReDo — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# El archivo .env NUNCA se sube a git (está en .gitignore).
# ============================================================

# ── Red doméstica ────────────────────────────────────────────
# Rango de red a escanear en formato CIDR (Enrutamiento entre Dominios sin Clases)
REDO_NETWORK=192.168.XX.0/24

# ── NTFY (alertas de red al móvil) ──────────────────────────
# Topic privado compartido con MediDo para alertas del ecosistema hogarOS.
# Generar con: python -c "import secrets; print('hogaros-' + secrets.token_hex(4))"
NTFY_TOPIC=
